TELEGRAM_BOT_TOKEN=paste_new_token_from_botfather_here
BTC_WALLET=
LTC_WALLET=
# Comma-separated Telegram numeric user IDs (get yours from @userinfobot)
ADMIN_USER_IDS=

# HTTP API for the BIN sorter HTML. Railway sets PORT automatically — do not set LEADBOT_HTTP_PORT there unless you know you need it.
# Local default: http://127.0.0.1:8787
LEADBOT_HTTP_PORT=8787
# LEADBOT_API_SECRET=

# Optional: absolute path to banner image for /start (else use assets/header.png)
# BOT_HEADER_IMAGE=
